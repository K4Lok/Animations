---
import { resolveLocale } from "../i18n/config";
import { t } from "../i18n/ui";

const locale = resolveLocale(Astro.currentLocale);
const ui = t(locale);
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <a class="logo" href="#top">{ui.brandWord} <span class="logo__dim">{ui.brandDim}</span></a>
    <p>
      {ui.footerTagline} {ui.footerInspired}
      <a href="https://animations.dev" target="_blank" rel="noopener noreferrer">Emil Kowalski</a>.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 96px;
    border-top: 1px solid var(--border-hairline);
  }
  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 13px;
    color: var(--color-muted-ash);
  }
  .site-footer__inner a[href^="http"] {
    color: var(--color-midnight-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--border-hairline);
  }
  .site-footer__inner a[href^="http"]:hover {
    border-bottom-color: var(--color-midnight-ink);
  }
  .logo {
    font-weight: 700;
    text-decoration: none;
    color: var(--color-midnight-ink);
  }
  .logo__dim {
    color: var(--color-muted-ash);
    font-weight: 500;
  }
  @media (max-width: 560px) {
    .site-footer__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
