---
import { LOCALES, localeMeta, localizedPath, resolveLocale } from "../i18n/config";
import { t } from "../i18n/ui";

const locale = resolveLocale(Astro.currentLocale);
const ui = t(locale);
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="logo" href="#top" aria-label={ui.homeAria}>
      <span class="logo__mark" aria-hidden="true"></span>
      <span class="logo__word">{ui.brandWord}<span class="logo__dim">{ui.brandDim}</span></span>
    </a>
    <div class="langswitch" data-langswitch>
      <button
        type="button"
        class="langswitch__trigger"
        id="lang-trigger"
        aria-haspopup="listbox"
        aria-expanded="false"
        aria-label={ui.langLabel}
      >
        <svg class="langswitch__globe" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M3 12h18M12 3c2.5 2.5 2.5 15.5 0 18M12 3c-2.5 2.5-2.5 15.5 0 18"></path>
        </svg>
        <span class="langswitch__current">{localeMeta[locale].label}</span>
        <svg class="langswitch__chevron" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 9l6 6 6-6"></path>
        </svg>
      </button>
      <ul class="langswitch__menu" role="listbox" aria-label={ui.langLabel} tabindex="-1" hidden>
        {
          LOCALES.map((loc) => (
            <li role="none">
              <a
                role="option"
                aria-selected={loc === locale}
                href={localizedPath(loc, "/")}
                class:list={["langswitch__option", { "is-active": loc === locale }]}
                lang={localeMeta[loc].htmlLang}
              >
                <span class="langswitch__check" aria-hidden="true">✓</span>
                <span class="langswitch__name">{localeMeta[loc].label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-canvas-white) 82%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border-hairline);
    transition:
      background 0.35s ease,
      backdrop-filter 0.35s ease,
      border-color 0.35s ease;
  }
  /* Once the glossary scrolls under the header the chrome melts away and the
     brand glides out of the centred column to the far-left gutter, floating
     over the content. */
  .site-header--pinned {
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 12px 24px;
  }
  .langswitch {
    margin-left: auto;
    position: relative;
  }
  .langswitch__trigger {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font: inherit;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-midnight-ink);
    background: color-mix(in srgb, var(--color-canvas-white) 70%, transparent);
    border: 1px solid var(--border-hairline);
    border-radius: 999px;
    padding: 6px 12px;
    cursor: pointer;
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease;
  }
  .langswitch__trigger:hover,
  .langswitch__trigger:focus-visible,
  .langswitch__trigger[aria-expanded="true"] {
    border-color: var(--color-midnight-ink);
    background: var(--color-canvas-white);
    outline: none;
    box-shadow: 0 1px 8px rgb(0 0 0 / 6%);
  }
  .langswitch__globe {
    width: 16px;
    height: 16px;
    color: var(--color-muted-ash);
    flex: none;
  }
  .langswitch__trigger:hover .langswitch__globe,
  .langswitch__trigger[aria-expanded="true"] .langswitch__globe {
    color: var(--color-midnight-ink);
  }
  .langswitch__current {
    white-space: nowrap;
  }
  .langswitch__chevron {
    width: 14px;
    height: 14px;
    color: var(--color-muted-ash);
    flex: none;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .langswitch__trigger[aria-expanded="true"] .langswitch__chevron {
    transform: rotate(180deg);
  }
  .langswitch__menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 168px;
    margin: 0;
    padding: 6px;
    list-style: none;
    background: var(--color-canvas-white);
    border: 1px solid var(--border-hairline);
    border-radius: 12px;
    box-shadow: var(--shadow-floating, 0 12px 32px rgb(0 0 0 / 12%));
    z-index: 60;
    transform-origin: top right;
    transform: scale(0.96) translateY(-4px);
    opacity: 0;
    transition:
      opacity 0.16s ease,
      transform 0.18s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .langswitch__menu:not([hidden]) {
    display: block;
  }
  .langswitch.is-open .langswitch__menu {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
  .langswitch__option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    font-size: 13px;
    color: var(--color-midnight-ink);
    text-decoration: none;
    transition: background 0.12s ease;
  }
  .langswitch__option:hover,
  .langswitch__option:focus-visible {
    background: var(--color-light-taupe, color-mix(in srgb, var(--color-midnight-ink) 6%, transparent));
    outline: none;
  }
  .langswitch__check {
    width: 14px;
    flex: none;
    color: var(--color-phoenix-orange, var(--color-midnight-ink));
    font-size: 12px;
    opacity: 0;
  }
  .langswitch__option.is-active {
    font-weight: 600;
  }
  .langswitch__option.is-active .langswitch__check {
    opacity: 1;
  }
  @media (max-width: 640px) {
    .site-header__inner {
      padding: 10px 16px;
      gap: 12px;
    }
    .logo {
      font-size: 15px;
    }
    .langswitch__trigger {
      padding: 6px 10px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .langswitch__chevron,
    .langswitch__menu {
      transition: none;
    }
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-midnight-ink);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.2px;
    /* At rest the brand lines up with the 1200px centred column; when pinned
       the margin collapses so it slides to the far-left edge. Animating
       margin-left (px -> px) means the move eases both ways. */
    margin-left: max(0px, calc((100vw - 1200px) / 2));
    transition: margin-left 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .site-header--pinned .logo {
    margin-left: 0;
  }
  .logo__word {
    display: inline-flex;
    align-items: baseline;
  }
  .logo__dim {
    color: var(--color-muted-ash);
    font-weight: 500;
    margin-left: 0.32em;
    max-width: 10em;
    opacity: 1;
    overflow: hidden;
    white-space: nowrap;
    transition:
      max-width 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.5s ease,
      margin-left 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Drop "Vocabulary" only in the shifted form. */
  .site-header--pinned .logo__dim {
    max-width: 0;
    opacity: 0;
    margin-left: 0;
  }
  .logo__mark {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: var(--color-midnight-ink);
    position: relative;
  }
  .logo__mark::after {
    content: "";
    position: absolute;
    inset: 6px;
    border-radius: 999px;
    background: var(--color-canvas-white);
    animation: logo-pulse 2.4s ease-in-out infinite;
  }
  @keyframes logo-pulse {
    0%,
    100% {
      transform: scale(0.7);
      opacity: 0.85;
    }
    50% {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script>
  const langswitch = document.querySelector<HTMLElement>("[data-langswitch]");
  const trigger = document.getElementById("lang-trigger");
  const menu = langswitch?.querySelector<HTMLElement>(".langswitch__menu");
  const options = menu ? Array.from(menu.querySelectorAll<HTMLAnchorElement>(".langswitch__option")) : [];

  let closeTimer = 0;
  const isOpen = () => langswitch?.classList.contains("is-open") ?? false;

  const openMenu = () => {
    if (!langswitch || !menu || !trigger) return;
    window.clearTimeout(closeTimer);
    menu.hidden = false;
    requestAnimationFrame(() => langswitch.classList.add("is-open"));
    trigger.setAttribute("aria-expanded", "true");
    const active = options.find((o) => o.getAttribute("aria-selected") === "true") ?? options[0];
    active?.focus();
  };

  const closeMenu = (focusTrigger = false) => {
    if (!langswitch || !menu || !trigger) return;
    langswitch.classList.remove("is-open");
    trigger.setAttribute("aria-expanded", "false");
    window.clearTimeout(closeTimer);
    closeTimer = window.setTimeout(() => (menu.hidden = true), 200);
    if (focusTrigger) trigger.focus();
  };

  trigger?.addEventListener("click", () => (isOpen() ? closeMenu() : openMenu()));

  document.addEventListener("click", (e) => {
    if (isOpen() && langswitch && !langswitch.contains(e.target as Node)) closeMenu();
  });

  langswitch?.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && isOpen()) {
      e.preventDefault();
      closeMenu(true);
      return;
    }
    if ((e.key === "ArrowDown" || e.key === "ArrowUp") && options.length) {
      e.preventDefault();
      if (!isOpen()) {
        openMenu();
        return;
      }
      const idx = options.indexOf(document.activeElement as HTMLAnchorElement);
      const next =
        e.key === "ArrowDown"
          ? (idx + 1) % options.length
          : (idx - 1 + options.length) % options.length;
      options[next]?.focus();
    }
  });

  const header = document.querySelector<HTMLElement>(".site-header");
  const glossary = document.getElementById("glossary");

  let ticking = false;
  const update = () => {
    const trigger = glossary ? glossary.offsetTop - 64 : 200;
    header?.classList.toggle("site-header--pinned", window.scrollY >= trigger);
    ticking = false;
  };
  window.addEventListener(
    "scroll",
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    },
    { passive: true }
  );
  window.addEventListener("resize", update, { passive: true });
  update();
</script>
