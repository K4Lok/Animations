---

<header class="site-header">
  <div class="site-header__inner">
    <a class="logo" href="#top" aria-label="Animation Vocabulary home">
      <span class="logo__mark" aria-hidden="true"></span>
      <span class="logo__word">Animation<span class="logo__dim">Vocabulary</span></span>
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-canvas-white) 82%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border-hairline);
    transition:
      background 0.35s ease,
      backdrop-filter 0.35s ease,
      border-color 0.35s ease;
  }
  /* Once the glossary scrolls under the header the chrome melts away and the
     brand glides out of the centred column to the far-left gutter, floating
     over the content. */
  .site-header--pinned {
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 12px clamp(16px, 2vw, 28px);
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-midnight-ink);
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.2px;
    /* At rest the brand lines up with the 1200px centred column; when pinned
       the margin collapses so it slides to the far-left edge. Animating
       margin-left (px -> px) means the move eases both ways. */
    margin-left: max(0px, calc((100vw - 1200px) / 2));
    transition: margin-left 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .site-header--pinned .logo {
    margin-left: 0;
  }
  .logo__word {
    display: inline-flex;
    align-items: baseline;
  }
  .logo__dim {
    color: var(--color-muted-ash);
    font-weight: 500;
    margin-left: 0.32em;
    max-width: 10em;
    opacity: 1;
    overflow: hidden;
    white-space: nowrap;
    transition:
      max-width 0.8s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.5s ease,
      margin-left 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  /* Drop "Vocabulary" only in the shifted form. */
  .site-header--pinned .logo__dim {
    max-width: 0;
    opacity: 0;
    margin-left: 0;
  }
  .logo__mark {
    width: 22px;
    height: 22px;
    border-radius: 7px;
    background: var(--color-midnight-ink);
    position: relative;
  }
  .logo__mark::after {
    content: "";
    position: absolute;
    inset: 6px;
    border-radius: 999px;
    background: var(--color-canvas-white);
    animation: logo-pulse 2.4s ease-in-out infinite;
  }
  @keyframes logo-pulse {
    0%,
    100% {
      transform: scale(0.7);
      opacity: 0.85;
    }
    50% {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>(".site-header");
  const glossary = document.getElementById("glossary");

  let ticking = false;
  const update = () => {
    const trigger = glossary ? glossary.offsetTop - 64 : 200;
    header?.classList.toggle("site-header--pinned", window.scrollY >= trigger);
    ticking = false;
  };
  window.addEventListener(
    "scroll",
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    },
    { passive: true }
  );
  window.addEventListener("resize", update, { passive: true });
  update();
</script>
