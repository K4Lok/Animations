---
import { categories } from "../data/terms";
---

<aside class="catnav" aria-label="Categories">
  <div class="catnav__inner">
    <div class="catnav__search">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        type="search"
        id="term-search"
        placeholder="Search patterns…"
        autocomplete="off"
        aria-label="Search animation patterns"
      />
    </div>
    <nav class="catnav__list" aria-label="Jump to category">
      <p class="catnav__heading">On this page</p>
      {
        categories.map((c, i) => (
          <a class="catnav__item" href={`#${c.id}`} data-pill={c.id}>
            <span class="catnav__num">{String(i + 1).padStart(2, "0")}</span>
            <span class="catnav__label">{c.title}</span>
            <span class="catnav__count">{c.terms.length}</span>
          </a>
        ))
      }
    </nav>
    <p class="catnav__empty" id="search-empty" hidden>
      No patterns match <span></span>.
    </p>
  </div>
</aside>

<style>
  .catnav {
    position: sticky;
    top: 85px;
    align-self: start;
  }
  .catnav__inner {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .catnav__search {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 38px;
    padding: 0 12px;
    border-radius: 10px;
    border: 1px solid var(--border-hairline);
    background: var(--color-canvas-white);
    color: var(--color-muted-ash);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .catnav__search:focus-within {
    border-color: var(--color-midnight-ink);
    box-shadow: var(--shadow-interactive);
  }
  .catnav__search input {
    border: 0;
    outline: 0;
    background: transparent;
    font: inherit;
    font-size: 14px;
    color: var(--color-midnight-ink);
    width: 100%;
  }
  .catnav__heading {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--color-muted-ash);
    padding: 0 10px;
    margin-bottom: 8px;
  }
  .catnav__list {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .catnav__item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-muted-ash);
    border-left: 2px solid transparent;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.2s ease;
  }
  .catnav__item:hover {
    color: var(--color-midnight-ink);
    background: var(--color-whisper-gray);
  }
  .catnav__num {
    font-size: 11px;
    font-variant-numeric: tabular-nums;
    color: var(--color-muted-ash);
    opacity: 0.7;
  }
  .catnav__label {
    flex: 1;
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1.2;
  }
  .catnav__count {
    font-size: 11px;
    font-variant-numeric: tabular-nums;
    color: var(--color-muted-ash);
    background: var(--color-light-taupe);
    border-radius: 999px;
    padding: 2px 7px;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .catnav__item:hover .catnav__count,
  .catnav__item.is-active .catnav__count {
    opacity: 1;
  }
  .catnav__item.is-active {
    color: var(--color-midnight-ink);
    background: var(--color-whisper-gray);
    border-left-color: var(--color-phoenix-orange);
  }
  .catnav__item.is-active .catnav__num {
    color: var(--color-phoenix-orange);
    opacity: 1;
  }
  .catnav__empty {
    font-size: 13px;
    color: var(--color-muted-ash);
    padding: 0 10px;
  }
  .catnav__empty span {
    color: var(--color-midnight-ink);
    font-weight: 500;
  }
  @media (max-width: 900px) {
    .catnav {
      position: static;
      margin-bottom: 32px;
      order: -1;
    }
    .catnav__list {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 4px;
    }
    .catnav__heading {
      display: none;
    }
  }
</style>

<script>
  const search = document.getElementById("term-search") as HTMLInputElement | null;
  const empty = document.getElementById("search-empty");
  const cards = Array.from(document.querySelectorAll<HTMLElement>(".term-card"));
  const sections = Array.from(document.querySelectorAll<HTMLElement>(".cat"));
  const items = Array.from(document.querySelectorAll<HTMLAnchorElement>(".catnav__item"));

  // Live search filter
  search?.addEventListener("input", () => {
    const q = search.value.trim().toLowerCase();
    let anyVisible = false;
    for (const card of cards) {
      const hay = (card.dataset.term ?? "") + " " + (card.textContent ?? "").toLowerCase();
      const match = q === "" || hay.includes(q);
      card.style.display = match ? "" : "none";
      if (match) anyVisible = true;
    }
    for (const section of sections) {
      const visible = section.querySelectorAll<HTMLElement>(
        '.term-card:not([style*="display: none"])'
      ).length;
      section.style.display = visible === 0 && q !== "" ? "none" : "";
    }
    if (empty) {
      empty.hidden = anyVisible || q === "";
      const span = empty.querySelector("span");
      if (span) span.textContent = `“${search.value.trim()}”`;
    }
  });

  // Smooth-scroll a category section into view on click
  for (const item of items) {
    item.addEventListener("click", (e) => {
      const id = item.dataset.pill;
      const target = id ? document.getElementById(id) : null;
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
      history.replaceState(null, "", `#${id}`);
      items.forEach((p) => p.classList.remove("is-active"));
      item.classList.add("is-active");
    });
  }

  // Scrollspy: highlight the item for the section nearest the top of the viewport
  const byId = new Map(items.map((p) => [p.dataset.pill, p]));
  let active: string | null = null;
  const setActive = (id: string | null) => {
    if (id === active) return;
    active = id;
    items.forEach((p) => p.classList.remove("is-active"));
    if (id) byId.get(id)?.classList.add("is-active");
  };
  const computeActive = () => {
    const line = 120; // px below the viewport top that counts as "current"
    let best: { id: string; top: number } | null = null;
    let firstVisible: string | null = null;
    for (const s of sections) {
      if (s.style.display === "none") continue;
      if (firstVisible === null) firstVisible = s.id;
      const top = s.getBoundingClientRect().top - line;
      if (top <= 0 && (!best || top > best.top)) best = { id: s.id, top };
    }
    setActive(best?.id ?? firstVisible);
  };
  let ticking = false;
  const onScroll = () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      computeActive();
      ticking = false;
    });
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", onScroll, { passive: true });
  computeActive();
</script>
